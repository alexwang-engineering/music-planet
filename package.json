{
  "name": "music-planet",
  "productName": "Music Planet",
  "version": "1.0.0",
  "description": "3D NetEase Cloud Music Player",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac --dir"
  },
  "build": {
    "appId": "com.wjl.music-planet",
    "productName": "Music Planet",
    "mac": {
      "category": "public.app-category.music",
      "target": [{ "target": "dir", "arch": ["arm64", "x64"] }]
    },
    "files": ["main.js", "app/**/*"],
    "extraResources": [
      { "from": "node_modules/NeteaseCloudMusicApi", "to": "api", "filter": ["**/*", "!**/node_modules/.cache/**"] }
    ]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "NeteaseCloudMusicApi": "^4.28.0"
  }
}
